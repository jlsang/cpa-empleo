# Copia este archivo como .env y rellena los valores.

# Clave de API de Google Gemini (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# Modelo de Gemini a usar (opcional)
GEMINI_MODEL=gemini-flash-latest

# Puerto del servidor (opcional)
PORT=3000

# --- Almacenamiento ---
# Backend de almacenamiento: "local" (archivo JSON) o "firestore".
STORAGE_BACKEND=local

# --- Firebase Firestore (solo si STORAGE_BACKEND=firestore) ---
# Ruta al archivo JSON de la cuenta de servicio de Firebase.
# Descárgalo en: Consola de Firebase > Configuración del proyecto > Cuentas de servicio > Generar nueva clave privada.
FIREBASE_SERVICE_ACCOUNT=./firebase-service-account.json

# Nombre de la colección de Firestore (opcional).
FIRESTORE_COLECCION=candidatos
